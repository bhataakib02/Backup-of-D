# Database Configuration
DATABASE_URL=postgresql://cybersec_user:cybersec_password@localhost:5432/cybersecurity_db
REDIS_URL=redis://localhost:6379/0

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-here-change-in-production

# API Keys - Threat Intelligence
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
OTX_API_KEY=your_otx_api_key_here
SHODAN_API_KEY=your_shodan_api_key_here
CENSYS_API_ID=your_censys_api_id_here
CENSYS_API_SECRET=your_censys_api_secret_here

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com

# Notification Services
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Cloud Storage (Optional)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_S3_BUCKET=your_s3_bucket_name_here
AWS_REGION=us-east-1

# Azure Storage (Optional)
AZURE_STORAGE_ACCOUNT_NAME=your_azure_storage_account_here
AZURE_STORAGE_ACCOUNT_KEY=your_azure_storage_key_here

# Google Cloud (Optional)
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id_here
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Security Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/0
MAX_CONTENT_LENGTH=16777216  # 16MB

# ML Model Configuration
MODEL_UPDATE_INTERVAL=3600  # 1 hour in seconds
MODEL_RETRAIN_THRESHOLD=1000  # Retrain after 1000 new samples
CONFIDENCE_THRESHOLD=0.8  # Minimum confidence for predictions

# Sandbox Configuration
CUCKOO_API_URL=http://localhost:8090
CUCKOO_API_KEY=your_cuckoo_api_key_here
SANDBOX_TIMEOUT=300  # 5 minutes

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/cybersecurity.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# Monitoring Configuration
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601

# Development Configuration
DEBUG=True
TESTING=False
FLASK_DEBUG=True

# Production Configuration (Override in production)
# FLASK_ENV=production
# DEBUG=False
# FLASK_DEBUG=False
# SECRET_KEY=your-production-secret-key
# JWT_SECRET=your-production-jwt-secret



